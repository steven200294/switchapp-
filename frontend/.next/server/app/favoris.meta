{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/favoris/layout,_N_T_/favoris/page,_N_T_/favoris"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/favoris/__PAGE__",
    "/favoris",
    "/_index",
    "/_head"
  ]
}