      "regex": "^/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/users/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
