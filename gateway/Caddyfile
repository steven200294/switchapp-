{
	admin off
}

# ── Local dev: single entry point on :80 ──
:{$GATEWAY_PORT:80} {

	# API: /api/* → backend
	handle /api/* {
		reverse_proxy api:{$API_PORT:4001}
	}

	# Grafana: /grafana/* → grafana (strip prefix)
	handle_path /grafana/* {
		reverse_proxy grafana:3000
	}

	# MinIO storage: /storage/* → minio (strip prefix)
	handle_path /storage/* {
		reverse_proxy minio:9000
	}

	# Admin panel: /admin/* → admin app (strip prefix)
	handle_path /admin/* {
		reverse_proxy admin:{$ADMIN_PORT:3002}
	}

	# Everything else → frontend
	handle {
		reverse_proxy frontend:{$FRONTEND_PORT:3001}
	}
}
