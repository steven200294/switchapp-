# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=switchapp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=switchapp
POSTGRES_PORT=5432
DATABASE_URL=postgresql://switchapp:changeme@postgres:5432/switchapp

# ── Redis ──────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_PORT=6379
REDIS_URL=redis://:changeme@redis:6379

# ── API ────────────────────────────────────
API_PORT=4001
NODE_ENV=development
JWT_SECRET=changeme-generate-a-real-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3001

# ── Frontend ───────────────────────────────
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1

# ── MinIO (object storage) ─────────────────
MINIO_ROOT_USER=switchapp
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET_PROPERTIES=properties
MINIO_BUCKET_AVATARS=avatars
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000

# ── Admin ─────────────────────────────────
ADMIN_PORT=3002
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3100

# ── Gateway ───────────────────────────────
GATEWAY_PORT=80

# ── Monitoring ─────────────────────────────
GRAFANA_PORT=3100
PROMETHEUS_PORT=9090
LOKI_PORT=3200
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=switchapp
