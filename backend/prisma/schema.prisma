generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

// ── Auth schema (Supabase — DO NOT MODIFY) ───────────────

model AuthUser {
  id                 String    @id @db.Uuid
  email              String?   @db.VarChar(255)
  encrypted_password String?   @db.VarChar(255)
  email_confirmed_at DateTime? @db.Timestamptz(6)
  created_at         DateTime? @db.Timestamptz(6)
  updated_at         DateTime? @db.Timestamptz(6)
  raw_app_meta_data  Json?
  raw_user_meta_data Json?
  aud                String?   @db.VarChar(255)
  role               String?   @db.VarChar(255)
  last_sign_in_at    DateTime? @db.Timestamptz(6)
  is_sso_user        Boolean   @default(false)
  is_anonymous       Boolean   @default(false)

  @@map("users")
  @@schema("auth")
}

// ── Public schema ────────────────────────────────────────

model User {
  id            String    @id @db.Uuid
  first_name    String?
  last_name     String?
  age           Int?
  profession    String?
  phone         String?
  bio           String?
  avatar_url    String?
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  username      String?
  is_verified   Boolean   @default(false)
  display_name  String?
  email         String?
  full_name     String?
  date_of_birth DateTime? @db.Date
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@map("users")
  @@schema("public")
}

model UserProfile {
  id                       String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String?   @unique
  full_name                String?
  city                     String?
  country                  String?   @default("France")
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)
  budget_min               Int?      @default(0)
  budget_max               Int?      @default(100000)
  preferred_property_types String[]  @default([])
  preferred_amenities      String[]  @default([])
  surface_min              Int?
  preferred_district       String?
  preferred_neighborhood   String?
  user_id                  String    @id @db.Uuid
  avatar_url               String?
  age                      Int?
  profession               String?
  phone                    String?
  birthdate                DateTime? @db.Date
  bio                      String?
  first_name               String?
  last_name                String?
  date_of_birth            DateTime? @db.Date
  languages                String?   @default("{}")
  verified                 Boolean?  @default(false)
  last_seen_at             DateTime? @db.Timestamptz(6)
  user_type                String?   @default("tenant")
  registration_ip          String?
  phone_verified_at        DateTime? @db.Timestamptz(6)
  phone_country_code       String?
  phone_number             String?

  properties Property[]

  @@map("user_profiles")
  @@schema("public")
}

model Property {
  id                            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id                      String    @db.Uuid
  title                         String
  description                   String?   @default("")
  property_type                 String?   @default("apartment")
  address                       String?   @default("")
  city                          String?   @default("")
  postal_code                   String?   @default("")
  country                       String?   @default("France")
  latitude                      Float?
  longitude                     Float?
  surface_area                  Int?      @default(0)
  rooms                         Int?      @default(1)
  bedrooms                      Int?      @default(1)
  bathrooms                     Int?      @default(1)
  max_occupants                 Int?      @default(1)
  amenities                     String[]  @default([])
  monthly_rent                  Int?      @default(0)
  deposit                       Int?      @default(0)
  utilities_included            Boolean?  @default(false)
  furnished                     Boolean?  @default(false)
  smoking_allowed               Boolean?  @default(false)
  pets_allowed                  Boolean?  @default(false)
  photos                        String[]  @default([])
  available_from                DateTime? @db.Timestamptz(6)
  available_until               DateTime? @db.Timestamptz(6)
  minimum_stay                  Int?      @default(7)
  maximum_stay                  Int?
  instant_booking               Boolean?  @default(false)
  status                        String?   @default("published")
  roommates                     Int?      @default(0)
  max_roommates                 Int?      @default(1)
  cover_image                   String?
  compatibility_score           Int?      @default(80)
  tags                          String[]  @default([])
  created_at                    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime? @default(now()) @db.Timestamptz(6)
  district                      String?
  neighborhood                  String?
  is_available                  Boolean   @default(true)
  occupancy_status              String?   @default("tenant")
  lease_type                    String?   @default("classic")
  exchange_authorization_status String?   @default("not_declared")
  equipment                     Json?     @default("{}")
  published                     Boolean   @default(false)
  photo_paths                   String[]  @default([])
  cover_path                    String?

  owner    UserProfile  @relation(fields: [owner_id], references: [user_id])
  swipes   Swipe[]
  favorites Favorite[]

  @@index([owner_id])
  @@index([published, status])
  @@index([city])
  @@index([created_at])
  @@map("properties")
  @@schema("public")
}

model Swipe {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  property_id String   @db.Uuid
  action      String
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  property Property @relation(fields: [property_id], references: [id])

  @@unique([user_id, property_id])
  @@index([user_id])
  @@map("matching_swipes")
  @@schema("public")
}

model Match {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_a     String   @db.Uuid
  user_b     String   @db.Uuid
  property_a String   @db.Uuid
  property_b String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  conversations Conversation[]

  @@index([user_a])
  @@index([user_b])
  @@map("matches")
  @@schema("public")
}

model Conversation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  last_message_at   DateTime? @db.Timestamptz(6)
  last_message_text String?
  match_id          String?   @db.Uuid

  match              Match?                    @relation(fields: [match_id], references: [id])
  messages           Message[]
  participants       ConversationParticipant[]

  @@map("conversations")
  @@schema("public")
}

model ConversationParticipant {
  conversation_id String   @db.Uuid
  user_id         String   @db.Uuid
  joined_at       DateTime @default(now()) @db.Timestamptz(6)
  last_read_at    DateTime? @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversation_id], references: [id])

  @@id([conversation_id, user_id])
  @@index([user_id])
  @@map("conversation_participants")
  @@schema("public")
}

model Message {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String   @db.Uuid
  sender_id       String   @db.Uuid
  content         String?
  attachment_url  String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversation_id], references: [id])

  @@index([conversation_id, created_at])
  @@map("messages")
  @@schema("public")
}

model Favorite {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  property_id String   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  property Property @relation(fields: [property_id], references: [id])

  @@unique([user_id, property_id])
  @@index([user_id])
  @@map("favorites")
  @@schema("public")
}

model UserSwitchPass {
  user_id    String    @id @db.Uuid
  balance    Int       @default(0)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_switch_passes")
  @@schema("public")
}

model AdminUser {
  user_id String @id @db.Uuid

  @@map("admin_users")
  @@schema("public")
}

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String
  title      String
  body       String?
  data       Json      @default("{}")
  is_read    Boolean   @default(false)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  read_at    DateTime? @db.Timestamptz(6)
  content    String?

  @@map("notifications")
  @@schema("public")
}

model GeocodingCache {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  address     String   @default("")
  city        String
  postal_code String   @default("")
  country     String   @default("France")
  latitude    Float
  longitude   Float
  provider    String   @default("nominatim")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([address, city, postal_code, country])
  @@map("geocoding_cache")
  @@schema("public")
}
